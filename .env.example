# ==================== 云途安（新供应商）配置 ====================
YT_API_BASE=https://ss.yuntinan.com/prod-api
YT_USERNAME=your_yuntinan_username
YT_PASSWORD=your_yuntinan_password

# 已知设备号列表（逗号分隔），新增设备时在这里添加即可
# 系统启动时会自动从云途安API补充未列出的设备
YT_DEVICE_NUMBERS=device1,device2,device3

# ==================== 旧供应商配置 ====================
OLD_SUPPLIER_USERNAME=your_old_supplier_username
OLD_SUPPLIER_PASSWORD=your_old_supplier_password

# 是否启用无头模式（true=后台运行，false=显示浏览器）
CRAWL_HEADLESS=true

# ==================== 服务配置 ====================
# 服务端口
PORT=3000

# Token密钥（用于身份验证签名，生产环境请修改为随机字符串）
# 生成方法：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_SECRET=change-this-to-random-string-in-production

# ==================== 新I日供应商API配置 ====================
# 启用新I日供应商API同步（默认false）
ENABLE_OLD_SYNC=false

# API基础地址
OLD_API_BASE=http://60.188.243.23:28111

# API认证信息
OLD_API_USER=your_api_user
OLD_API_KEY=your_api_key

# 旧供应商爬虫开关（已禁用，使用新API替代）
# 如需重新启用Playwright爬虫，设置为 true
ENABLE_OLD_CRAWLER=false

# ==================== MySQL 数据库配置 ====================
# 注意：本地和云端共享同一个阿里云MySQL数据库
MYSQL_HOST=8.130.161.244
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=agri_gateway

# ==================== 本地开发配置 ====================
# 是否启用定时任务（本地开发建议设为false，避免影响云端数据）
ENABLE_SCHEDULER=false

# ==================== 日志配置（可选）====================
# LOG_LEVEL=info
